# Force LF line endings for shell scripts on all platforms
*.sh        text eol=lf
*.ps1       text eol=crlf
*.md        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.env*      text eol=lf
